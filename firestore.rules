rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: analyses
    // Document ID: {analysisId}
    // Fields:
    //   - userId: string (required)
    //   - appName: string (required)
    //   - userStatus: string (required, enum: ['New', 'Returning'])
    //   - instructions: string (required)
    //   - voiceScript: string (required)
    //   - arrowPosition: map (optional, {x: number, y: number})
    //   - imageUrl: string (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.createdAt is timestamp;
    }

    function isValidAnalysis(data) {
      return data.keys().hasAll(['userId', 'appName', 'userStatus', 'instructions', 'voiceScript', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.appName is string && data.appName.size() < 100 &&
             data.userStatus in ['New', 'Returning'] &&
             data.instructions is string && data.instructions.size() < 2000 &&
             data.voiceScript is string && data.voiceScript.size() < 2000 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /analyses/{analysisId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidAnalysis(request.resource.data);
      allow update: if isDocOwner() && isValidAnalysis(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
